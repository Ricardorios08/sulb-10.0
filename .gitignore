# Ignore everything by default
/*

# Except these directories
!/backend/
!/frontend/

# Except this file
!/.gitignore

# Still ignore node_modules inside backend and frontend if they exist
**/node_modules/
**/.env
**/*.log
**/tmp/
**/dist/
**/build/
**/Thumbs.db
**/desktop.ini
**/~$*
**/nul
**/**/nul
